{
  "expo": {
    "name": "GetMe",
    "slug": "getme",
    "scheme": "getme",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "social.getme.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "GetMe needs access to your photos so you can upload portfolio images and a profile picture.",
        "NSCameraUsageDescription": "GetMe needs camera access so you can take a profile photo directly in the app."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "social.getme.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-image-picker",
      "expo-notifications"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fe4b3125-e499-495a-af44-c7c9b07d0f80"
      }
    },
    "owner": "nihalg123"
  }
}
